# ─── AI Provider ─────────────────────────────────────────────────────────────
# Which provider to use: "ollama" | "gemini" | "claude"
# NOTE: "ollama" requires a local Ollama process — does NOT work on Vercel.
#       Use "gemini" or "claude" for any hosted deployment.
AI_PROVIDER=gemini

# Gemini (free tier — https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# Claude / Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama — local development only
OLLAMA_MODEL=qwen2.5-coder:14b
# OLLAMA_HOST=http://localhost:11434

# ─── App metadata database ───────────────────────────────────────────────────
# PostgreSQL for storing connections, conversations, and messages.
#
# Local dev — Docker (default, set automatically by setup.sh):
APP_DATABASE_URL=postgresql://querypal:querypal@localhost:5433/querypal
# Local dev — Homebrew PostgreSQL:
# APP_DATABASE_URL=postgresql://localhost:5432/querypal
#
# Production / Vercel (free tier available):
#   Neon     → https://neon.tech       (use the -pooler endpoint URL)
#   Supabase → https://supabase.com
#   Railway  → https://railway.app
# APP_DATABASE_URL=postgresql://user:password@host:5432/querypal

# ─── Optional tuning ─────────────────────────────────────────────────────────
# Schema cache TTL in milliseconds (default: 5 minutes)
# SCHEMA_CACHE_TTL_MS=300000
